{
  "name": "agentport",
  "version": "0.1.0",
  "description": "Port your AI coding agent config across tools and devices. Canonical IR + bidirectional adapters for Claude Code, OpenCode, and Codex.",
  "type": "module",
  "bin": {
    "agentport": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "cli": "tsx src/cli.ts",
    "web": "tsx src/web/server.ts"
  },
  "dependencies": {
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
